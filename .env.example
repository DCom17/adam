# Jarvis Voice Local — secrets & machine values.
# Copy this file to ".env" and fill in real values. NEVER commit your real .env.

# REQUIRED. The single bearer token that gates the API. Generate a long random
# value, e.g. in PowerShell:
#   python -c "import secrets; print(secrets.token_hex(24))"
JARVIS_TOKEN=replace-with-a-long-random-token

# --- Web Push (optional) ----------------------------------------------------
# Enables Home Screen PWA notifications (SMS replies, briefings, results) even when
# the app is closed. LEAVE BLANK — the server auto-generates a matched VAPID keypair
# on first start (private PEM at VAPID_PRIVATE_PEM, default data/state/vapid_private.pem).
# Only set this if you want to pin your OWN keypair; then VAPID_PRIVATE_PEM must point
# to the matching private key.
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Optional override for where the private PEM lives (absolute or project-relative).
# VAPID_PRIVATE_PEM=data/state/vapid_private.pem

# --- Twilio inbound SMS (optional) ------------------------------------------
# Enables the hands-free "text JARVIS: ..." path. Jarvis POLLS Twilio for inbound
# texts (no public webhook needed). Get these from your Twilio Console dashboard.
# Leave blank to disable. The Auth Token is the only secret here.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
OWNER_PHONE=
# Optional: only needed if you ALSO expose the legacy public POST /sms webhook.
# Polling does not use it. If blank, defaults to public_base_url + /sms.
TWILIO_WEBHOOK_URL=

# --- Google Calendar bridge (optional) --------------------------------------
# The random token generated INSIDE your own Apps Script bridge (run
# setCalendarSyncToken() once and copy what it logs). The setup wizard walks you
# through it. Leave blank to keep calendar disabled. Paired with
# integrations.google_calendar.bridge_url in settings.json.
GOOGLE_CALENDAR_TOKEN=

# --- Hunter dashboard bridge (optional) -------------------------------------
# The random token you generate INSIDE your own copy of the Hunter dashboard's
# Apps Script (run setHunterToken() once and copy what it logs). The setup wizard
# (/setup-hunter) walks you through it. Leave blank to keep Hunter disabled.
# Paired with integrations.hunter.bridge_url in settings.json.
HUNTER_TOKEN=

# --- Gmail bridge (optional) ------------------------------------------------
# The random token generated INSIDE your own Apps Script bridge (run
# setGmailBridgeToken() once and copy what it logs). The setup wizard walks you
# through it. Leave blank to keep email disabled. Paired with
# integrations.gmail.bridge_url in settings.json. Reads + drafts only out of the
# box; sending stays off unless you set integrations.gmail.allow_send=true.
GMAIL_BRIDGE_TOKEN=

# --- LinkedIn API auto-post lane (optional, advanced) -----------------------
# Only needed for the OPTIONAL auto-post lane. The default draft lane needs
# NOTHING here. Bring your own LinkedIn Developer App + a member access token
# with w_member_social. The token is short-lived (~60 days) — re-paste when it
# expires. The setup wizard (/setup-linkedin) walks you through it. Leave blank
# to keep LinkedIn in draft-only mode. Paired with integrations.linkedin.* in
# settings.json.
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
