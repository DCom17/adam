# Copy this file to .env and fill in your secrets. NEVER commit .env.
# Only fill the section(s) for modules you actually enable.

# --- Dashboard module ---
# The deployment token from YOUR Apps Script web app (see setup_dashboard.md).
# Must match the VERIFY_TOKEN you paste into apps_script_doGet.js.
DASHBOARD_TOKEN=

# --- Calendar module ---
# The token for YOUR Calendar Bridge Apps Script (see setup_calendar.md).
CALENDAR_TOKEN=

# --- Voice module (v1.1, advanced) ---
# A long random string you invent; it is the bearer token securing your voice server.
ADAM_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- SMS module (v1.1, advanced — Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
OWNER_PHONE=
TWILIO_WEBHOOK_URL=
